{
  "name": "agent-sdd",
  "version": "1.3.0",
  "description": "Spec-Driven Development helper CLI: freshness tokens, scope drift stubs, spec-lint, approval ceremony.",
  "keywords": [
    "spec-driven-development",
    "sdd",
    "cli",
    "spec-lint",
    "freshness-token",
    "baseline"
  ],
  "license": "MIT",
  "author": "cyberash <cyberash-dev@yandex.com>",
  "homepage": "https://github.com/cyberash-dev/agent-sdd#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cyberash-dev/agent-sdd.git"
  },
  "bugs": {
    "url": "https://github.com/cyberash-dev/agent-sdd/issues"
  },
  "type": "module",
  "prettier": "@cyberash-dev/dev-tooling/prettier.base.json",
  "bin": {
    "sdd": "dist/cli.js"
  },
  "files": [
    "dist",
    "schema",
    "rules",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc && chmod +x dist/cli.js",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "node --import tsx --test tests/unit/*.test.ts",
    "test:integration": "node --import tsx --test tests/integration/*.test.ts",
    "test:coverage": "c8 --config .c8rc.json node --import tsx --test tests/unit/*.test.ts tests/integration/*.test.ts",
    "coverage:ratchet": "tsx scripts/coverage-ratchet.ts",
    "coverage:gate": "npm run test:coverage && npm run coverage:ratchet",
    "tsc": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint:spec": "node dist/cli.js lint",
    "prepublishOnly": "npm run tsc && npm test && npm run build",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "dependencies": {
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@cyberash-dev/dev-tooling": "9.0.0",
    "@types/node": "22.19.17",
    "c8": "11.0.0",
    "eslint": "9.39.4",
    "prettier": "3.8.3",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
